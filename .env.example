# Select the market data provider: "demo", "shioaji", or "upstash".
MARKET_DATA_PROVIDER=demo

# Shioaji credentials are server-side only. Do not expose them with NEXT_PUBLIC_.
SHIOAJI_API_KEY=
SHIOAJI_SECRET_KEY=
SHIOAJI_SYMBOLS=2330,2317,2454,2412
SHIOAJI_SNAPSHOT_FILE=shioaji-snapshot.json

# MarketPulse must keep Shioaji in simulation mode until a separate trading
# safety review explicitly changes that boundary.
SHIOAJI_FORCE_SIMULATION=true

# Upstash Redis REST boundary for NAS -> cloud -> Vercel deployments.
# The NAS bridge needs the standard write token. Vercel can use a read-only
# token via UPSTASH_REDIS_REST_READ_TOKEN.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_REDIS_REST_READ_TOKEN=
MARKETPULSE_SNAPSHOT_KEY=marketpulse:snapshot
MARKETPULSE_SNAPSHOT_MAX_AGE_MS=20000
MARKETPULSE_UPSTASH_PUSH_INTERVAL_SECONDS=5
